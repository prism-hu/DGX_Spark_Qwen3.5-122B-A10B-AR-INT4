# DGX Spark Qwen3.5-122B v2
#
# All-in-one: vLLM 0.19 + Hybrid INT4+FP8 + INT8 LM Head v2
# Result: 51 tok/s on DGX Spark with MTP-2 (+80% vs baseline)
#
# Tested with: vLLM 0.19.1
# WARNING: Patches are version-specific. Newer vLLM may need re-qualification.
#
# Prerequisites:
#   - A vLLM 0.19.x Docker image compiled for SM121 (TORCH_CUDA_ARCH_LIST=12.1a)
#   - Replace the FROM line below with your vLLM base image name
#
# Build:
#   docker build -t vllm-qwen35-v2 -f docker/Dockerfile.v2 .
#
# Run (256K context, 51 tok/s):
#   docker run --gpus all --net=host -v ~/models:/models \
#     vllm-qwen35-v2 \
#     serve /models/qwen35-122b-hybrid-int4fp8 \
#     --served-model-name qwen --port 8000 \
#     --max-model-len 262144 --gpu-memory-utilization 0.90 \
#     --reasoning-parser qwen3 --attention-backend FLASHINFER \
#     --speculative-config '{"method":"mtp","num_speculative_tokens":2}'

# Base: vLLM 0.19.1 compiled for SM121 (built in Step 3 of README via install.sh).
# Tested build: 0.19.1.dev0+g2a69949bd (commit 2a69949bd, 2026-04-04).
# WARNING: Do NOT use other vLLM versions without re-testing patches.
#
# Default base is `vllm-sm121:latest` (the standard install.sh build).
# Optional override: `docker build --build-arg VLLM_BASE=vllm-sm121-pr38325:latest ...`
# uses the variant base built via `install.sh --with-pr38325`, which adds vLLM
# PR #38325 (swapAB SM120 CUTLASS blockwise FP8 GEMM) for an extra +0.76% on
# shared_expert decode (cumulative +2.0% over baseline vs autotune-only).
ARG VLLM_BASE=vllm-sm121:latest
FROM ${VLLM_BASE}

# Patch 1: Hybrid INT4+FP8 dispatch for shared expert dense layers
COPY patches/01-hybrid-int4-fp8/inc.py \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/quantization/inc.py

# Patch 2: INT8 LM Head v2 — baked into the image at build time
# (patch_int8_lmhead.py is a pure text transform of logits_processor.py;
# running it here makes container startup go directly to `vllm serve`)
COPY patches/03-int8-lm-head/patch_int8_lmhead.py /opt/patches/patch_int8_lmhead.py
RUN python3 /opt/patches/patch_int8_lmhead.py \
 && grep -q DGX_SPARK_INT8_LMHEAD_V2 /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/logits_processor.py

# Patch 3 (prism-hu fork): the base's torchaudio is ABI-built against torch 2.14
# (the cu130 nightly index cross-pins torchvision/torchaudio to a newer torch),
# so its libtorchaudio.abi3.so fails to load against our torch 2.13 base with
# "undefined symbol: torch_exception_get_what_without_backtrace" — which crashes
# vLLM at startup (transformers imports torchaudio). LLM serving does not need
# torchaudio and transformers tolerates its absence, so remove it.
RUN pip uninstall -y torchaudio || true \
 && ! python3 -c 'import torchaudio' 2>/dev/null

# Patch 4 (prism-hu fork): vLLM 0.19.0 requires `fastapi[standard] >= 0.115.0`
# with NO upper bound, so the base pulls fastapi 0.137 — which adds `_IncludedRouter`
# to app.routes. vLLM's prometheus_fastapi_instrumentator (8.0.0, latest) can't
# iterate that and raises "'_IncludedRouter' object has no attribute 'path'" on
# EVERY request (incl /health → all 500). Verified by repro: the break is ONLY
# at 0.137; 0.136 is fine AND keeps starlette 1.3.1 (which sse-starlette 3.4.4 /
# model-hosting-container-standards need >=0.49.1). So just cap below 0.137 —
# do NOT pin to old 0.115 (that downgrades starlette and breaks sse-starlette).
RUN pip install 'fastapi[standard]<0.137' \
 && python3 -c 'import fastapi,starlette;print("fastapi",fastapi.__version__,"starlette",starlette.__version__)'

ENTRYPOINT ["vllm"]
CMD ["serve", "--help"]
